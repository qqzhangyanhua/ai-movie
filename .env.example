# Database
POSTGRES_USER=aimovie
POSTGRES_PASSWORD=aimovie_secret
POSTGRES_DB=aimovie
DATABASE_URL=postgresql+asyncpg://aimovie:aimovie_secret@postgres:5432/aimovie

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=change-me-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for API keys (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=change-me-generate-a-real-key

# Upload limits
MAX_FILE_SIZE_MB=10
MAX_PHOTOS_PER_PROJECT=50
MAX_STORAGE_PER_USER_MB=500

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
